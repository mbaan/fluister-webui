# Copy this file to `.env` and fill in values. `.env` is gitignored.
# The app loads `.env` at startup (without overriding real environment vars).

# Required for speaker diarization (pyannote.audio 4.x). Steps:
#   1. Create a free read token: https://huggingface.co/settings/tokens
#   2. Accept the model terms (once) for:
#        https://huggingface.co/pyannote/speaker-diarization-community-1
# Without this, transcription still works — only speaker labels are disabled.
HF_TOKEN=

# ── Optional overrides (defaults shown) ──────────────────────────────
# TRANSCRIBE_MODEL=large-v3
# TRANSCRIBE_DEVICE=auto            # auto | cuda | cpu
# TRANSCRIBE_COMPUTE_TYPE=auto      # auto | float16 | int8 | ...
# TRANSCRIBE_BATCH_SIZE=2          # low default: whisper shares the GPU with the tidy LLM
# TRANSCRIBE_LANGUAGE=auto          # auto | nl | en
# TRANSCRIBE_DIARIZE=true           # run speaker diarization on every file
# TRANSCRIBE_SPEAKER_THRESHOLD=0.45 # cosine sim to match a known voice
# TRANSCRIBE_HOST=127.0.0.1
# TRANSCRIBE_PORT=8000

# ── Readable transcripts (optional local LLM tidy pass) ──────────────
# Best-effort post-pass: punctuation, paragraphs, "uhm" removal — tidies, never
# fixes. fluister starts/stops llama-server itself. ON by default; the model is
# resolved into the HF cache on first use (like large-v3), so the first run
# downloads ~18.6 GB. Set TRANSCRIBE_TIDY=false to disable. Defaults shown:
# TRANSCRIBE_TIDY=true
# TRANSCRIBE_LLM_REPO=unsloth/Qwen3-30B-A3B-Instruct-2507-GGUF
# TRANSCRIBE_LLM_FILE=Qwen3-30B-A3B-Instruct-2507-Q4_K_M.gguf
# TRANSCRIBE_LLM_MODEL=/abs/path/to/local.gguf   # optional: local file, overrides repo/file
# TRANSCRIBE_LLM_PORT=8080
# TRANSCRIBE_LLM_CTX=8192
# TRANSCRIBE_LLM_HEALTH_TIMEOUT=120                     # secs to wait for /health
# TRANSCRIBE_LLM_REQUEST_TIMEOUT=120                    # secs per tidy request
